{
  "name": "case-study-sdd-development",
  "version": "0.0.0",
  "main": "index.js",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "start": "gulp dev",
    "app:install": "npm install --workspaces --include-workspace-root",
    "dev:help": "gulp dev:help",
    "dev:backend": "npm run dev --workspace @fleur-memoire/backend",
    "dev:frontend": "npm run dev --workspace @fleur-memoire/frontend",
    "dev:db:start": "gulp dev:db:start",
    "dev:db:stop": "gulp dev:db:stop",
    "dev:db:status": "gulp dev:db:status",
    "build:backend": "npm run build --workspace @fleur-memoire/backend",
    "build:frontend": "npm run build --workspace @fleur-memoire/frontend",
    "test:backend": "npm run test --workspace @fleur-memoire/backend",
    "test:frontend": "npm run test --workspace @fleur-memoire/frontend",
    "test:e2e:frontend": "npm run e2e --workspace @fleur-memoire/frontend",
    "tdd:backend": "gulp tdd:backend",
    "tdd:frontend": "gulp tdd:frontend",
    "typecheck:backend": "npm run typecheck --workspace @fleur-memoire/backend",
    "typecheck:frontend": "npm run typecheck --workspace @fleur-memoire/frontend",
    "journal": "gulp journal:generate",
    "docs:serve": "gulp mkdocs:serve",
    "docs:stop": "gulp mkdocs:stop",
    "docs:build": "gulp mkdocs:build",
    "vault:encrypt": "gulp vault:encrypt",
    "vault:decrypt": "gulp vault:decrypt",
    "vault:view": "gulp vault:view",
    "vault:rekey": "gulp vault:rekey",
    "claude:yolo": "claude --dangerously-skip-permissions",
    "copilot:yolo": "copilot --allow-all-tools",
    "codex:yolo": "codex --yolo",
    "gemini:yolo": "gemini --yolo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k2works/{project_name}.git"
  },
  "keywords": [
    "ai",
    "programming",
    "learning"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/k2works/{project_name}/issues"
  },
  "homepage": "https://github.com/k2works/{project_name}#readme",
  "type": "module",
  "dependencies": {
    "@k2works/claude-code-booster": "^2.7.1",
    "dotenv": "^17.2.3",
    "gulp": "^5.0.0"
  }
}
