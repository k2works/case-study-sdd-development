{
  "name": "case-study-sdd-development",
  "version": "0.0.0",
  "main": "index.js",
  "scripts": {
    "start": "gulp dev",
    "journal": "gulp journal:generate",
    "docs:serve": "gulp mkdocs:serve",
    "docs:stop": "gulp mkdocs:stop",
    "docs:build": "gulp mkdocs:build",
    "vault:encrypt": "gulp vault:encrypt",
    "vault:decrypt": "gulp vault:decrypt",
    "vault:view": "gulp vault:view",
    "vault:rekey": "gulp vault:rekey",
    "claude:yolo": "claude --dangerously-skip-permissions",
    "copilot:yolo": "copilot --allow-all-tools",
    "codex:yolo": "codex --yolo",
    "gemini:yolo": "gemini --yolo",
    "webshop:backend": "bash ops/scripts/nix-java-exec.sh apps/webshop/backend ./gradlew bootRun",
    "webshop:backend:test": "bash ops/scripts/nix-java-exec.sh apps/webshop/backend ./gradlew test",
    "webshop:frontend": "cd apps/webshop/frontend && npm run dev",
    "webshop:frontend:test": "cd apps/webshop/frontend && npm run test",
    "webshop:db": "cd apps/webshop && docker compose up -d db",
    "webshop:db:stop": "gulp dev:webshop:db:stop",
    "webshop:backend:prod": "gulp dev:webshop:backend:prod",
    "webshop:build": "gulp dev:webshop:build",
    "tdd:webshop:backend": "gulp tdd:webshop:backend",
    "tdd:webshop:frontend": "gulp tdd:webshop:frontend",
    "dev:help": "gulp dev:help",
    "setup:webshop": "gulp setup:webshop"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k2works/case-study-sdd-development.git"
  },
  "keywords": [
    "ai",
    "programming",
    "learning"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/k2works/case-study-sdd-development/issues"
  },
  "homepage": "https://github.com/k2works/case-study-sdd-development#readme",
  "type": "module",
  "dependencies": {
    "@k2works/claude-code-booster": "^2.7.1",
    "dotenv": "^17.2.3",
    "gulp": "^5.0.0"
  }
}
