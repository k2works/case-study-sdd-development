# 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env

# MkDocs サーバー設定
MKDOCS_PORT=8000

# Docker 設定（通常は設定不要、Docker Desktop が自動設定）
# DOCKER_HOST=npipe:////./pipe/docker_engine

# SSH 接続設定
DEV_SSH_HOST=xxxxxxxx
DEV_SSH_USER=xxxxxxxx
STG_SSH_HOST=xxxxxxxx
STG_SSH_USER=xxxxxxxx
PRD_SSH_HOST=xxxxxxxx
PRD_SSH_USER=xxxxxxxx

# Heroku 開発環境設定
DEV_HEROKU_APP=sdd-case-study-codex-take1
DEV_HEROKU_STACK=container
DEV_INTERNAL_API_PORT=3000
DEV_NEXT_PUBLIC_API_BASE_URL=/api
DEV_DOCKER_PLATFORM=linux/amd64
