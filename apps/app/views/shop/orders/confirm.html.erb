<h1>注文確認</h1>

<div class="card mb-4">
  <div class="card-body">
    <h5>商品</h5>
    <p><%= @product.name %> - <%= number_to_currency(@product.price, unit: "¥", format: "%u%n") %></p>

    <h5>届け日</h5>
    <p><%= @order_params[:delivery_date] %></p>

    <h5>届け先</h5>
    <p>
      <%= @order_params[:recipient_name] %><br>
      <%= @order_params[:address] %><br>
      <%= @order_params[:phone] %>
    </p>

    <h5>お届けメッセージ</h5>
    <p><%= @order_params[:message] %></p>
  </div>
</div>

<%= form_with url: shop_orders_path, method: :post, local: true do |form| %>
  <% @order_params.each do |key, value| %>
    <%= form.hidden_field key, value: value, name: "order[#{key}]" %>
  <% end %>

  <div class="d-flex gap-2">
    <%= link_to "修正する", new_shop_order_path(product_id: @product.id), class: "btn btn-secondary" %>
    <%= form.submit "注文を確定する", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>
