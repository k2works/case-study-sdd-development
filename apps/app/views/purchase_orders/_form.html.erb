<div class="card">
  <div class="card-body">
    <%= form_with(url: purchase_orders_path, method: :post) do |form| %>
      <% if flash[:alert] %>
        <div class="alert alert-danger">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <div class="mb-3">
        <%= form.label :item_id, "単品", class: "form-label" %>
        <%= form.select :item_id,
              items.map { |i| ["#{i.name}（仕入先: #{i.supplier.name} / 購入単位: #{i.purchase_unit} / リードタイム: #{i.lead_time_days}日）", i.id] },
              { prompt: "単品を選択してください" },
              class: "form-select",
              data: { items: items.map { |i| { id: i.id, purchase_unit: i.purchase_unit, lead_time_days: i.lead_time_days, supplier_name: i.supplier.name } }.to_json } %>
      </div>

      <div class="mb-3">
        <%= form.label :quantity, "発注数量", class: "form-label" %>
        <%= form.number_field :quantity, class: "form-control", min: 1, value: purchase_order.quantity %>
        <div class="form-text">購入単位の整数倍で指定してください。</div>
      </div>

      <div class="mb-3">
        <%= form.label :desired_delivery_date, "希望納品日", class: "form-label" %>
        <%= form.date_field :desired_delivery_date, class: "form-control", min: Date.current.to_s, value: purchase_order.desired_delivery_date %>
      </div>

      <div class="d-flex gap-2">
        <%= form.submit "発注を確定する", class: "btn btn-primary" %>
        <%= link_to "キャンセル", purchase_orders_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>
