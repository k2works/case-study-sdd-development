<div class="py-3">
  <h1 class="h3 mb-4">入荷記録</h1>

  <div class="card mb-4">
    <div class="card-header">
      <strong>発注情報</strong>
    </div>
    <div class="card-body">
      <table class="table table-borderless mb-0">
        <tbody>
          <tr>
            <th class="w-25">単品</th>
            <td><%= @purchase_order.item.name %></td>
          </tr>
          <tr>
            <th>仕入先</th>
            <td><%= @purchase_order.supplier.name %></td>
          </tr>
          <tr>
            <th>発注数量</th>
            <td><%= @purchase_order.quantity %></td>
          </tr>
          <tr>
            <th>希望納品日</th>
            <td><%= @purchase_order.desired_delivery_date %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <%= form_with(url: purchase_order_arrivals_path(@purchase_order), method: :post) do |form| %>
        <% if flash[:alert] %>
          <div class="alert alert-danger">
            <%= flash[:alert] %>
          </div>
        <% end %>

        <div class="mb-3">
          <%= form.label :quantity, "入荷数量", class: "form-label" %>
          <%= form.number_field :quantity, class: "form-control", min: 1, value: @arrival.quantity %>
        </div>

        <div class="mb-3">
          <%= form.label :arrived_at, "入荷日", class: "form-label" %>
          <%= form.date_field :arrived_at, class: "form-control", value: Date.current %>
        </div>

        <div class="d-flex gap-2">
          <%= form.submit "入荷を記録する", class: "btn btn-success" %>
          <%= link_to "キャンセル", purchase_order_path(@purchase_order), class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
