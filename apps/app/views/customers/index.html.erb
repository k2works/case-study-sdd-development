<h1>得意先一覧</h1>

<% if @customers.any? %>
  <div class="card">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-striped">
          <thead class="table-dark">
            <tr>
              <th>ID</th>
              <th>氏名</th>
              <th>電話番号</th>
              <th>注文数</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @customers.each do |customer| %>
              <tr>
                <td><%= customer.id %></td>
                <td><%= customer.name %></td>
                <td><%= customer.phone || "-" %></td>
                <td><%= customer.orders.size %></td>
                <td><%= link_to "編集", edit_customer_path(customer), class: "btn btn-sm btn-outline-primary" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% else %>
  <div class="alert alert-info">
    得意先はまだ登録されていません。得意先は会員登録時に自動作成されます。
  </div>
<% end %>
