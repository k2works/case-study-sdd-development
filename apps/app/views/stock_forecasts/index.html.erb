<div class="container-fluid py-3">
  <h1 class="h3 mb-4">在庫推移</h1>

  <div class="card mb-4">
    <div class="card-body">
      <%= form_tag stock_forecasts_path, method: :get, class: "row g-3 align-items-end" do %>
        <div class="col-md-4">
          <%= label_tag :item_id, "単品", class: "form-label" %>
          <%= select_tag :item_id,
                options_from_collection_for_select(@items, :id, :name, params[:item_id]&.to_i),
                prompt: "単品を選択", class: "form-select" %>
        </div>
        <div class="col-md-3">
          <%= label_tag :start_date, "開始日", class: "form-label" %>
          <%= date_field_tag :start_date, @start_date || Date.current, class: "form-control" %>
        </div>
        <div class="col-md-3">
          <%= label_tag :end_date, "終了日", class: "form-label" %>
          <%= date_field_tag :end_date, @end_date || Date.current + 13.days, class: "form-control" %>
        </div>
        <div class="col-md-2">
          <%= submit_tag "表示", class: "btn btn-primary w-100" %>
        </div>
      <% end %>
    </div>
  </div>

  <% if @selected_item && @forecast %>
    <div class="card">
      <div class="card-header">
        <strong><%= @selected_item.name %></strong>
        — 品質維持日数: <%= @selected_item.quality_retention_days %> 日
        / 購入単位: <%= @selected_item.purchase_unit %> 本
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
              <tr>
                <th>日付</th>
                <th class="text-end">良品在庫</th>
                <th class="text-end">入荷予定</th>
                <th class="text-end">引当済み</th>
                <th class="text-end">廃棄対象</th>
                <th class="text-end"><strong>有効在庫</strong></th>
              </tr>
            </thead>
            <tbody>
              <% @forecast.each do |daily| %>
                <tr class="<%= 'table-danger' if daily[:effective_stock] < 0 %>">
                  <td><%= daily[:date].strftime("%m/%d (%a)") %></td>
                  <td class="text-end"><%= daily[:available_stock] %></td>
                  <td class="text-end text-info"><%= daily[:incoming] %></td>
                  <td class="text-end text-warning"><%= daily[:allocated] %></td>
                  <td class="text-end text-danger"><%= daily[:expired] %></td>
                  <td class="text-end"><strong><%= daily[:effective_stock] %></strong></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>
