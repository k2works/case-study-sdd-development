<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "フレール・メモワール" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container-fluid">
          <%= link_to "フレール・メモワール", root_path, class: "navbar-brand" %>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
              <li class="nav-item">
                <%= link_to "商品管理", products_path, class: "nav-link #{request.path.start_with?('/products') ? 'active' : ''}" %>
              </li>
              <li class="nav-item">
                <%= link_to "単品管理", items_path, class: "nav-link #{request.path.start_with?('/items') ? 'active' : ''}" %>
              </li>
              <li class="nav-item">
                <%= link_to "受注管理", orders_path, class: "nav-link #{request.path.start_with?('/orders') ? 'active' : ''}" %>
              </li>
              <li class="nav-item">
                <%= link_to "在庫推移", stock_forecasts_path, class: "nav-link #{request.path.start_with?('/stock_forecasts') ? 'active' : ''}" %>
              </li>
              <li class="nav-item">
                <%= link_to "発注管理", purchase_orders_path, class: "nav-link #{request.path.start_with?('/purchase_orders') ? 'active' : ''}" %>
              </li>
              <li class="nav-item">
                <%= link_to "出荷管理", shipments_path, class: "nav-link #{request.path.start_with?('/shipments') ? 'active' : ''}" %>
              </li>
              <li class="nav-item">
                <%= link_to "得意先", customers_path, class: "nav-link #{request.path.start_with?('/customers') ? 'active' : ''}" %>
              </li>
            </ul>
            <ul class="navbar-nav">
              <li class="nav-item">
                <span class="nav-link text-light"><%= current_user.name || current_user.email %></span>
              </li>
              <li class="nav-item">
                <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "btn btn-outline-light btn-sm mt-1" %>
              </li>
            </ul>
          </div>
        </div>
      </nav>
    <% end %>

    <div class="container">
      <% flash.each do |type, message| %>
        <div class="alert alert-<%= type == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
